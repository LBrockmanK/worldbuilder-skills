filters:
  or:
    - 'type == "project"'
    - 'type == "reference"'

views:
  - type: table
    name: All
    order:
      - file.name
      - type
      - status
      - last_updated

  - type: table
    name: Draft
    filters: 'status == "draft"'
    order:
      - file.name
      - type
      - status
      - last_updated

  - type: table
    name: Complete
    filters: 'status == "complete"'
    order:
      - file.name
      - type
      - status
      - last_updated
