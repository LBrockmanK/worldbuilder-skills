filters:
  and:
    - 'type == "event"'
    - file.inFolder("notes")

views:
  - type: table
    name: All
    order:
      - file.name
      - description
      - tags
      - characters
      - location
      - layer
      - timestamp

  - type: table
    name: Open
    filters:
      or:
        - tags.contains("human-ready")
        - tags.contains("agent-ready")
    order:
      - file.name
      - description
      - tags
      - characters
      - location
      - layer
      - timestamp

  - type: table
    name: Complete
    filters: 'tags.contains("complete")'
    order:
      - file.name
      - description
      - tags
      - characters
      - location
      - layer
      - timestamp
