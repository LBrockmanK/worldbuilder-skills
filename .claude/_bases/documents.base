filters:
  and:
  - type != null
  - '!file.inFolder("_bases")'
  - '!file.inFolder("_templates")'
  - '!file.inFolder("rules")'
  - file.basename != "Home"
  - file.basename != "glossary"
  - file.basename != "inbox"
  - file.basename != "index"
  - file.basename != "log"
views:
- type: table
  name: All documents
  groupBy:
    property: type
    direction: ASC
  order:
  - file.name
  - title
  - description
  - tags
  - timestamp
- type: table
  name: Open
  filters:
    or:
    - file.hasTag("human-ready")
    - file.hasTag("agent-ready")
  groupBy:
    property: type
    direction: ASC
  order:
  - file.name
  - title
  - description
  - tags
  - timestamp
- type: table
  name: Closed
  filters:
    or:
    - file.hasTag("complete")
    - file.hasTag("deprecated")
    - file.hasTag("abandoned")
    - file.hasTag("archived")
  groupBy:
    property: type
    direction: ASC
  order:
  - file.name
  - title
  - description
  - tags
  - timestamp
