filters:
  and:
  - type != null
  - '!file.inFolder("_bases")'
  - '!file.inFolder("_templates")'
  - '!file.inFolder("rules")'
  - file.basename != "Home"
  - file.basename != "glossary"
  - file.basename != "inbox"
  - file.basename != "index"
  - file.basename != "log"
  - or:
    - file.hasTag("human-ready")
    - file.hasTag("agent-ready")
views:
- type: table
  name: By type
  groupBy:
    property: type
    direction: ASC
  order: &id001
  - file.name
  - type
  - tags
  - title
  - description
  - timestamp
- type: table
  name: human-ready
  filters: file.hasTag("human-ready")
  order: *id001
- type: table
  name: agent-ready
  filters: file.hasTag("agent-ready")
  order: *id001
