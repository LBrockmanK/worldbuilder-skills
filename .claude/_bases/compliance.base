filters:
  and:
  - file.ext == "md"
  - '!file.inFolder("_bases")'
  - '!file.inFolder("_templates")'
  - '!file.inFolder("rules")'
  - file.basename != "Home"
  - file.basename != "glossary"
  - file.basename != "inbox"
  - file.basename != "index"
  - file.basename != "log"
formulas:
  missing_status: if(!file.hasTag("human-ready") && !file.hasTag("agent-ready") && !file.hasTag("complete") && !file.hasTag("deprecated") && !file.hasTag("abandoned") && !file.hasTag("archived"), "✗", "")
  missing_properties: if(type == null || type == "" || title == null || title == "" || description == null || description == "" || tags == null || date == null || timestamp == null || resources == null, "✗", "")
views:
- type: table
  name: Non-compliant
  filters:
    or:
    - '!file.hasTag("human-ready") && !file.hasTag("agent-ready") && !file.hasTag("complete") && !file.hasTag("deprecated") && !file.hasTag("abandoned") && !file.hasTag("archived")'
    - type == null || type == ""
    - title == null || title == ""
    - description == null || description == ""
    - tags == null
    - date == null
    - timestamp == null
    - resources == null
  order:
  - file.name
  - formula.missing_status
  - formula.missing_properties
  - type
  - title
  - tags
  - timestamp
